{
  "name": "qa-autopilot",
  "version": "0.0.0",
  "private": true,
  "description": "Operations-centric QA automation: triage, noise isolation, governance, self-healing.",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm -r --parallel run dev",
    "lint": "pnpm -r run lint",
    "test": "pnpm -r run test",
    "typecheck": "pnpm -r run typecheck",
    "build:turbo": "turbo run build"
  },
  "devDependencies": {
    "turbo": "^2.1.0",
    "typescript": "^5.6.0",
    "@types/node": "^22.0.0"
  }
}
