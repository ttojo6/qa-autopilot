# 거버넌스 영속화 (선택). 설정 시 CLI는 제안을 DB에 적재하고 콘솔은 DB에서 읽는다.
# 미설정 시: CLI는 artifacts/proposals.json 핸드오프, 콘솔은 그 파일 또는 시드.
DATABASE_URL=postgres://qa:qa@localhost:5433/qa

# AI 활성화 (선택). 미설정 시 Triage는 휴리스틱만, Remediation은 Null 생성기.
ANTHROPIC_API_KEY=

# 콘솔이 파일 핸드오프를 읽을 때만 사용 (DATABASE_URL 미설정 시).
QA_PROPOSALS_FILE=examples/demo/artifacts/proposals.json
